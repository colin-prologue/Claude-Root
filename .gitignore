# Spec-Kit - ignore potential credentials/auth tokens stored by Claude agent
.claude/settings.local.json

# Git worktrees
worktrees/

# LanceDB index (volatile cache — delete and regenerate via memory_sync if restored)
.specify/memory/.index/

# Oracle artifacts — meta-patterns belong in oracle bank, not this repo
.decisions/

# /speckit.run runtime artifacts (sentinels, run-lock, control-flow sidecar — per ADR-012, ADR-016)
# Declared once at template-setup time so the orchestrator never modifies .gitignore at runtime (FR-020).
specs/*/.run/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
