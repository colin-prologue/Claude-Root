{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{USER_HOME}}/.claude/hooks/pre-bash-guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{USER_HOME}}/.claude/hooks/pre-file-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{USER_HOME}}/.claude/hooks/stop-repetition-guard.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
